---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Contact Us" description="Contact Bright Futures School — 01457 878738 — 1 Friezland Lane, Greenfield, OL3 7EU">
  <div class="max-w-5xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-brand-navy mb-8 pb-4 border-b-4 border-brand-cyan">Contact Us</h1>

    <div class="grid md:grid-cols-2 gap-10">
      <!-- Left: details -->
      <div>
        <h2 class="section-heading mb-4">Find Us</h2>
        <address class="not-italic text-gray-700 space-y-1 mb-6">
          <p class="font-bold text-brand-navy">Bright Futures School</p>
          <p>1 Friezland Lane</p>
          <p>Greenfield</p>
          <p>Oldham</p>
          <p>OL3 7EU</p>
        </address>

        <h2 class="section-heading mb-4">School Hours</h2>
        <table class="text-sm text-gray-700 mb-6 w-full">
          <tbody>
            <tr><td class="pr-4 py-1 font-semibold">Mon / Tue / Thu / Fri</td><td>9.15am – 2.15pm</td></tr>
            <tr><td class="pr-4 py-1 font-semibold">Wednesday</td><td>10.00am – 3.00pm</td></tr>
          </tbody>
        </table>

        <h2 class="section-heading mb-4">Get in Touch</h2>
        <p class="mb-2">
          <a href="tel:01457878738" class="text-brand-cyan hover:text-brand-navy font-semibold text-lg">📞 01457 878738</a>
        </p>
        <p class="mb-2">
          <a href="mailto:office@brightfuturesschool.co.uk" class="text-brand-cyan hover:text-brand-navy">✉️ office@brightfuturesschool.co.uk</a>
        </p>
        <p class="text-sm text-gray-500 mt-4">
          To arrange a visit, please call or email the school office. We'd love to show you around.
        </p>
      </div>

      <!-- Right: enquiry form -->
      <div>
        <h2 class="section-heading mb-4">Send Us a Message</h2>
        <form id="contact-form" action="/api/contact" method="POST" class="space-y-4">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="first-name" class="block text-sm font-semibold text-gray-700 mb-1">First Name *</label>
              <input type="text" id="first-name" name="firstName" required
                class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-cyan" />
            </div>
            <div>
              <label for="last-name" class="block text-sm font-semibold text-gray-700 mb-1">Last Name *</label>
              <input type="text" id="last-name" name="lastName" required
                class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-cyan" />
            </div>
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">Email Address *</label>
            <input type="email" id="email" name="email" required
              class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-cyan" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1">Phone Number *</label>
            <input type="tel" id="phone" name="phone" required
              class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-cyan" />
          </div>
          <div>
            <label for="message" class="block text-sm font-semibold text-gray-700 mb-1">Message *</label>
            <textarea id="message" name="message" rows="5" required
              class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-cyan"></textarea>
          </div>
          <button type="submit" class="btn-primary w-full">Send Message</button>
          <p id="form-status" class="text-sm text-center hidden"></p>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLParagraphElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type=submit]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: new FormData(form),
      });
      if (res.ok) {
        form.innerHTML = '<p class="text-brand-green font-semibold text-center py-8">Thank you — your message has been sent. We will be in touch soon.</p>';
      } else {
        throw new Error('Server error');
      }
    } catch {
      status.textContent = 'Sorry, something went wrong. Please call us on 01457 878738.';
      status.className = 'text-sm text-center text-red-600';
      status.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Send Message';
    }
  });
</script>
