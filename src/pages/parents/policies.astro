---
import PageLayout from '@/layouts/PageLayout.astro';

const keyDocuments = [
  { name: 'School Prospectus (Nov 2023)',       file: 'prospectus-1123.pdf' },
  { name: 'SEND Information Report (Jan 2025)', file: 'SEND-Information-Report-2.pdf' },
];

const policies = [
  { name: 'Accessibility Plan 2024',                              file: 'Accessibility-Plan-2024.docx-2.pdf' },
  { name: 'Administration of Medicines 2024',                     file: 'Administration-of-Medicines-2024.docx.pdf' },
  { name: 'Admissions Policy Sept 2025',                          file: 'BFS-admissions-policy-Sept25.pdf' },
  { name: 'Anti-Bullying Policy 2026',                            file: 'Anti-bullying-Policy-2026.docx.pdf' },
  { name: 'Appeals Policy Jan 2023',                              file: 'Appeals-Policy-January-2023.pdf' },
  { name: 'Attendance Policy 2026',                               file: 'Attendance-policy-2026.docx-1.pdf' },
  { name: 'Behaviour Policy Jan 2026',                            file: 'Behaviour-policy-Jan-26.docx' },
  { name: 'Bereavement Policy Jan 2026',                          file: 'Bereavement-policy-Jan26.pdf' },
  { name: 'Complaints Procedure Feb 2026',                        file: 'Complaints-procedure-reviewed-Feb2026.pdf' },
  { name: 'Curriculum and Assessment Policy 2026',                file: 'Curriculum-and-Assessment-Policy-2026-.pdf' },
  { name: 'Curriculum and Assessment Policy 2026 (E-Learning)',   file: 'Curriculum-and-Assessment-Policy-2026- (1).pdf' },
  { name: 'Curriculum and Assessment Policy 2026 (English)',      file: 'Curriculum-and-Assessment-Policy-2026- (2).pdf' },
  { name: 'Curriculum and Assessment Policy 2026 (Marking)',      file: 'Curriculum-and-Assessment-Policy-2026- (3).pdf' },
  { name: 'Curriculum and Assessment Policy 2026 (Numeracy)',     file: 'Curriculum-and-Assessment-Policy-2026- (4).pdf' },
  { name: 'Curriculum and Assessment Policy 2026 (RSHE)',         file: 'Curriculum-and-Assessment-Policy-2026- (5).pdf' },
  { name: 'Curriculum and Assessment Policy 2026 (SMSC)',         file: 'Curriculum-and-Assessment-Policy-2026- (6).pdf' },
  { name: 'Curriculum and Assessment Policy 2026 (7)',            file: 'Curriculum-and-Assessment-Policy-2026- (7).pdf' },
  { name: 'Data Protection Policy Jul 2024',                      file: 'Data-Protection-Policy-Updated-Jul-2024.docx-1.pdf' },
  { name: 'DBS Policy 2023',                                      file: 'BFS-DBS-Policy-2023.pdf' },
  { name: 'Disciplinary Procedure Jan 2023',                      file: 'Disciplinary-procedure-Jan-23.pdf' },
  { name: 'Equal Opportunities Policy Jan 2025',                  file: 'Equal-Opps-Access-and-Disability-policy-January-2025.docx.pdf' },
  { name: 'Health and Safety Policy 2024',                        file: 'Health-and-Safety-Policy-2024.docx-2.pdf' },
  { name: 'Homework Policy 2022',                                 file: 'Homework-policy-2022.pdf' },
  { name: 'Illness Policy 2023',                                  file: 'Illness-Policy-2023.pdf' },
  { name: 'Mobile Phone Policy 2024',                             file: 'Mobile-Phone-Policy-for-Staff-and-Pupils-2024-1.pdf' },
  { name: 'Positive Handling Policy Sept 2024',                   file: 'Positive-handling-September-2024.docx-3.pdf' },
  { name: 'Privacy Notice (Pupils) Jul 2024',                     file: 'Privacy-notice-for-pupils-updated-July-24.docx-1.pdf' },
  { name: 'Risk Assessment Policy 2025',                          file: 'Risk_assessment_policy_2025.pdf' },
  { name: 'Safeguarding & Child Protection Policy 2025',          file: 'Safeguarding_Child_Protection_Policy_2025_BFS.pdf' },
  { name: 'Safer Recruitment Policy 2025',                        file: 'Safer-Recruitment-and-staff-selection-policy-2025.docx.pdf' },
  { name: 'School Taxi Policy 2023',                              file: 'School-taxi-policy-2023.pdf' },
  { name: 'Separated Parents Policy Oct 2025',                    file: 'Separated-Parents-Policy-updated-Oct-25.docx.pdf' },
  { name: 'Snow Policy Jan 2025',                                 file: 'Snow-policy-January-2025.docx.pdf' },
  { name: 'Student–School Agreement 2022',                        file: 'Student-school-agreement-2022.pdf' },
  { name: 'Toileting Policy Jan 2023',                            file: 'Toileting-policy-January-2023.pdf' },
  { name: 'Visitor Policy Jan 2025',                              file: 'Visitor-Policy-Jan-2025.docx.pdf' },
  { name: 'Volunteer Policy 2025',                                file: 'Volunteer-policy-2025.docx-Google-Docs.pdf' },
  { name: 'Whistleblowing Policy Jan 2022',                       file: 'Whistleblowing-Policy-Jan-2022.pdf' },
];
---
<PageLayout title="School Policies">
  <p class="text-gray-600 mb-8">All our school policies are available to download below. If you require a paper copy of any policy, please contact the school office.</p>

  <h2 class="section-heading mb-4">Key Documents</h2>
  <ul class="mb-10 space-y-2">
    {keyDocuments.map(doc => (
      <li>
        <a href={`/documents/${doc.file}`} target="_blank" rel="noopener"
           class="flex items-center gap-2 text-brand-cyan hover:text-brand-navy font-semibold transition-colors">
          <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
          {doc.name}
        </a>
      </li>
    ))}
  </ul>

  <h2 class="section-heading mb-4">School Policies</h2>
  <ul class="space-y-2">
    {policies.map(p => (
      <li>
        <a href={`/documents/${encodeURIComponent(p.file)}`} target="_blank" rel="noopener"
           class="flex items-center gap-2 text-brand-cyan hover:text-brand-navy transition-colors">
          <svg class="w-4 h-4 flex-shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
          {p.name}
        </a>
      </li>
    ))}
  </ul>

  <p class="text-xs text-gray-400 mt-8">Note: the curriculum policy document covers several subject areas — the numbered variants are separate subject-specific supplements. Please confirm the correct labelling with the school office.</p>
</PageLayout>
