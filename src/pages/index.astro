---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactBlock from '@/components/ContactBlock.astro';
import Testimonials from '@/components/Testimonials.astro';
---
<BaseLayout title="School For Children With Autism">
  <!-- Schema.org structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "School",
    "name": "Bright Futures School",
    "description": "A small, nurturing, special independent school for children with autism in Greenfield, Oldham.",
    "url": "https://bfswebsite.louismilburn.workers.dev",
    "logo": "https://bfswebsite.louismilburn.workers.dev/images/BFSlogo.jpg",
    "telephone": "01457878738",
    "email": "office@brightfuturesschool.co.uk",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "1 Friezland Lane",
      "addressLocality": "Greenfield",
      "addressRegion": "Oldham",
      "postalCode": "OL3 7EU",
      "addressCountry": "GB"
    },
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Thursday","Friday"], "opens": "09:15", "closes": "14:15" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Wednesday"], "opens": "10:00", "closes": "15:00" }
    ],
    "sameAs": ["https://www.facebook.com/BrightFuturesFriends/"]
  })} />

  <!-- Hero -->
  <section class="relative bg-brand-navy text-white overflow-hidden">
    <img src="/images/school-exterior.jpg" alt="Bright Futures School building" class="absolute inset-0 w-full h-full object-cover opacity-45" />
    <div class="relative max-w-4xl mx-auto px-4 py-20 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">Bright Futures School</h1>
      <p class="text-xl md:text-2xl text-brand-cyan font-semibold mb-6">A Special School for Children with Autism</p>
      <p class="text-lg text-gray-200 max-w-2xl mx-auto mb-8">
        A small, nurturing, special independent school in Greenfield offering a unique approach to autism education for children aged 5–16.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/contact" class="btn-primary">Arrange a Visit</a>
        <a href="/admissions" class="btn-outline border-white text-white hover:bg-white hover:text-brand-navy">Admissions</a>
      </div>
    </div>
  </section>

  <!-- Address & contact strip -->
  <section class="bg-brand-cyan text-white py-4">
    <div class="max-w-6xl mx-auto px-4 flex flex-col sm:flex-row justify-center items-center gap-4 sm:gap-10 text-sm font-semibold">
      <span>📍 1 Friezland Lane, Greenfield, OL3 7EU</span>
      <a href="tel:01457878738" class="text-white hover:underline">📞 01457 878738</a>
      <a href="mailto:office@brightfuturesschool.co.uk" class="text-white hover:underline">✉️ office@brightfuturesschool.co.uk</a>
    </div>
  </section>

  <!-- Welcome section -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="section-heading text-3xl mb-6">Welcome to Bright Futures School</h2>
    <div class="prose-bfs text-gray-700 space-y-4">
      <p>
        Bright Futures School is a small, nurturing, special independent school for children with autism with a low stimulus environment and a high level of 1-1 teaching by Learning Mentors that is overseen by qualified teaching staff.
      </p>
      <p>
        We offer a unique approach to autism education for children aged between 5 and 16 who have a diagnosis of autism: our staff are trained to change their communication and interaction style so that it removes demands from the pupils and reduces their anxieties.
      </p>
      <p>
        In February 2020, we moved into our beautiful, purpose built accommodation, provided by local company Robert Scott and Son. All pupils have their own 1-1 space.
      </p>
      <p>
        We have an excellent record of turning pupils' previous negative and unsuccessful experience of school, into a positive, rewarding and promising future.
      </p>
    </div>
    <a href="/about" class="btn-primary mt-6 inline-block">Find Out More</a>
  </section>

  <!-- Approach highlight -->
  <section class="bg-gray-50 py-12">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="section-heading text-2xl mb-6">Our Approach</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white rounded-lg shadow-sm p-6 border-t-4 border-brand-cyan">
          <h3 class="font-bold text-brand-navy text-lg mb-2">Low-Stimulus Environment</h3>
          <p class="text-gray-600 text-sm">Purposefully designed spaces that reduce sensory overload and support calm, focused learning.</p>
        </div>
        <div class="bg-white rounded-lg shadow-sm p-6 border-t-4 border-brand-green">
          <h3 class="font-bold text-brand-navy text-lg mb-2">1-1 Teaching</h3>
          <p class="text-gray-600 text-sm">Every pupil has their own dedicated Learning Mentor, overseen by qualified teaching staff.</p>
        </div>
        <div class="bg-white rounded-lg shadow-sm p-6 border-t-4 border-brand-navy">
          <h3 class="font-bold text-brand-navy text-lg mb-2">Guiding & R.D.I.</h3>
          <p class="text-gray-600 text-sm">Staff are trained in Relationship Development Intervention to reduce anxiety and build dynamic intelligence.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo grid -->
  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="section-heading text-2xl mb-6">Life at Bright Futures</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <img src="/images/gallery/bright-futures-04.jpg" alt="School exterior" class="rounded-lg object-cover w-full h-40" />
      <img src="/images/gallery/bright-futures-03.jpg" alt="Pupils at work" class="rounded-lg object-cover w-full h-40" />
      <img src="/images/gallery/bright-futures-05.jpg" alt="Classroom" class="rounded-lg object-cover w-full h-40" />
      <img src="/images/gallery/bright-futures-11.jpg" alt="Outdoor activities" class="rounded-lg object-cover w-full h-40" />
    </div>
    <a href="/gallery" class="btn-outline mt-6 inline-block">View Full Gallery</a>
  </section>

  <Testimonials />

  <!-- Quick links grid -->
  <section class="bg-brand-navy py-12">
    <div class="max-w-5xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
      <a href="/about/overview" class="group bg-white/10 hover:bg-brand-cyan rounded-lg p-5 text-white transition-colors flex flex-col items-center gap-3">
        <svg class="w-10 h-10 opacity-80 group-hover:opacity-100" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.966 8.966 0 00-6 2.292m0-14.25v14.25"/>
        </svg>
        <span class="font-semibold text-sm">Overview</span>
      </a>
      <a href="/friends" class="group bg-white/10 hover:bg-white rounded-lg p-5 text-white transition-colors flex flex-col items-center gap-3">
        <img src="/images/fbfs-logo.png" alt="Friends of Bright Futures School" class="w-14 h-14 object-contain rounded-full" />
        <span class="font-semibold text-sm group-hover:text-brand-navy">Friends of BFS</span>
      </a>
      <a href="/parents/policies" class="group bg-white/10 hover:bg-brand-cyan rounded-lg p-5 text-white transition-colors flex flex-col items-center gap-3">
        <svg class="w-10 h-10 opacity-80 group-hover:opacity-100" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"/>
        </svg>
        <span class="font-semibold text-sm">Policies</span>
      </a>
      <a href="/ofsted" class="group bg-white/10 hover:bg-white rounded-lg p-5 text-white transition-colors flex flex-col items-center gap-3">
        <img src="/images/bfs-ofsted-good-school.png" alt="Ofsted Good" class="w-14 h-14 object-contain" />
        <span class="font-semibold text-sm group-hover:text-brand-navy">Ofsted</span>
      </a>
    </div>
  </section>

  <ContactBlock />
</BaseLayout>
