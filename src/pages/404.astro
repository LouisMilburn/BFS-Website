---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found" description="The page you were looking for could not be found.">
  <div class="max-w-3xl mx-auto px-4 py-20 text-center">
    <p class="text-8xl font-bold text-brand-cyan mb-4">404</p>
    <h1 class="text-3xl font-bold text-brand-navy mb-4">Page not found</h1>
    <p class="text-gray-600 mb-10 max-w-md mx-auto">
      Sorry — we couldn't find the page you were looking for. It may have moved or the link may be out of date.
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <a href="/" class="bg-gray-50 hover:bg-brand-cyan hover:text-white rounded-lg p-4 text-brand-navy font-semibold text-sm transition-colors">
        Home
      </a>
      <a href="/about" class="bg-gray-50 hover:bg-brand-cyan hover:text-white rounded-lg p-4 text-brand-navy font-semibold text-sm transition-colors">
        About Us
      </a>
      <a href="/admissions" class="bg-gray-50 hover:bg-brand-cyan hover:text-white rounded-lg p-4 text-brand-navy font-semibold text-sm transition-colors">
        Admissions
      </a>
      <a href="/contact" class="bg-gray-50 hover:bg-brand-cyan hover:text-white rounded-lg p-4 text-brand-navy font-semibold text-sm transition-colors">
        Contact
      </a>
    </div>
  </div>
</BaseLayout>
