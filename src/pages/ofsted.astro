---
import PageLayout from '@/layouts/PageLayout.astro';
---
<PageLayout title="Ofsted — We Are a 'Good' School">
  <div class="prose-bfs">
    <div class="flex flex-col sm:flex-row items-start gap-8 mb-8">
      <img src="/images/bfs-ofsted-good-school.png" alt="Ofsted Good school badge" class="w-40 flex-shrink-0" />
      <div>
        <h2>Our Ofsted Report</h2>
        <p>
          Bright Futures School has, once again, been evaluated as a <strong>'Good' school</strong>, following a full Ofsted inspection over three days in May 2023.
        </p>
        <p>
          We are extremely proud of our staff team and of our students!
        </p>
        <p>
          In February 2025, following a successful material change application, we were granted approval to increase our registered pupil numbers to 18 in total.
        </p>
      </div>
    </div>

    <h2>Download Our Reports</h2>
    <ul class="space-y-3">
      <li>
        <a href="/documents/BFS-Ofsted-Report-May2023.pdf" target="_blank" rel="noopener" class="flex items-center gap-2 text-brand-cyan hover:text-brand-navy font-semibold">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
          Ofsted Report — May 2023 (PDF)
        </a>
      </li>
      <li>
        <a href="https://files.ofsted.gov.uk/v1/file/50272878" target="_blank" rel="noopener" class="flex items-center gap-2 text-brand-cyan hover:text-brand-navy font-semibold">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
          Ofsted Report — February 2025 (Ofsted.gov.uk)
        </a>
      </li>
      <li>
        <a href="/documents/BFS-Ofsted-Report-Jul2020.pdf" target="_blank" rel="noopener" class="flex items-center gap-2 text-brand-cyan hover:text-brand-navy">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
          Ofsted Report — July 2020 (PDF)
        </a>
      </li>
    </ul>
  </div>
</PageLayout>
