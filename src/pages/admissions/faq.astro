---
import PageLayout from '@/layouts/PageLayout.astro';

const faqs = [
  {
    q: "Who can attend Bright Futures School?",
    a: "We accept children and young people aged 5–16 who have a confirmed diagnosis of autism and an Education, Health and Care Plan (EHCP). We specialise in pupils whose autism significantly affects their ability to access a mainstream school environment."
  },
  {
    q: "Does my child need an EHCP to apply?",
    a: "Yes. All placements at Bright Futures School are funded through the Local Authority, which requires an EHCP to be in place. We are not able to accept privately funded placements. If your child does not yet have an EHCP, we'd encourage you to contact your Local Authority's SEND team to begin the assessment process."
  },
  {
    q: "How does the placement process work?",
    a: "There are two routes. If your Local Authority (LA) is considering Bright Futures as a placement for your child, they will contact us directly and we will arrange a visit before any decision is made. Alternatively, if you are a parent who would like to request a placement, you should ask your LA to name Bright Futures in your child's EHCP, and contact us directly to arrange an informal visit. You can also download our First Contact Form from the Admissions page."
  },
  {
    q: "What does it cost?",
    a: "Fees are paid entirely by the Local Authority — we do not accept private funding. As a parent, you should not be asked to contribute to school fees. Your LA's SEND team will handle funding arrangements."
  },
  {
    q: "Can my child start mid-year?",
    a: "Yes, where a place is available. We take new pupils throughout the academic year subject to capacity. Please contact us to discuss your child's situation."
  },
  {
    q: "What are the school hours?",
    a: "Monday, Tuesday, Thursday, and Friday: 9.15am – 2.15pm. Wednesday: 10.00am – 3.00pm."
  },
  {
    q: "What is the maximum class size?",
    a: "We are registered for up to 18 pupils in total. Every pupil has their own dedicated Learning Mentor and their own individual classroom space, so our model is one-to-one rather than class-based."
  },
  {
    q: "How do you handle my child's additional medical or physical needs?",
    a: "We have a medical room on site and our staff are trained in first aid and medication administration. Please contact us to discuss any specific health requirements — we assess each child's needs individually to ensure we can provide appropriate support."
  },
  {
    q: "What about the transition from primary school?",
    a: "We have experience supporting pupils making the move from primary to secondary settings. We take a gradual, pupil-centred approach to any transition, and work closely with families and previous schools to make the process as smooth as possible."
  },
  {
    q: "Do you provide school transport?",
    a: "Transport to and from school is the responsibility of the Local Authority, not the school itself. Most pupils travel by LA-arranged taxi. Please contact your LA's transport team to arrange this once a placement is confirmed."
  },
  {
    q: "Can I visit the school before applying?",
    a: "Absolutely — we actively encourage visits from prospective families and Local Authority representatives. Please contact us by phone or email to arrange a convenient time. We are proud of our school and love showing families what we do."
  },
  {
    q: "Do you cater for pupils with diagnoses beyond autism?",
    a: "Our specialist registration is for autism. Some of our pupils also have related conditions such as ADHD, anxiety disorders, or PDA. We assess each application individually — please speak to us about your child's specific profile."
  },
];
---
<PageLayout title="Admissions FAQ" description="Frequently asked questions about applying to Bright Futures School — EHCP, placement process, funding, and more.">
  <p class="text-gray-600 mb-8 text-lg">
    Answers to the questions we're most commonly asked by families and Local Authorities. If your question isn't here, please <a href="/contact" class="text-brand-cyan hover:text-brand-navy underline">contact us</a> directly.
  </p>

  <div class="space-y-5">
    {faqs.map((faq, i) => (
      <details class="group bg-gray-50 rounded-lg border border-gray-200 open:border-brand-cyan transition-colors">
        <summary class="flex items-center justify-between px-5 py-4 cursor-pointer font-semibold text-brand-navy list-none group-open:text-brand-cyan">
          {faq.q}
          <svg class="w-5 h-5 flex-shrink-0 ml-3 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="px-5 pb-4 text-gray-700 text-sm leading-relaxed border-t border-gray-200 pt-3">
          {faq.a}
        </div>
      </details>
    ))}
  </div>

  <div class="mt-10 bg-brand-cyan/10 border-l-4 border-brand-cyan rounded-r-lg p-6">
    <p class="font-semibold text-brand-navy mb-2">Still have questions?</p>
    <p class="text-gray-600 text-sm mb-4">We're happy to talk through any aspect of the admissions process. There's no obligation, and no question is too small.</p>
    <div class="flex gap-4 flex-wrap">
      <a href="/contact" class="btn-primary">Send us a message</a>
      <a href="tel:01457878738" class="btn-outline">Call 01457 878738</a>
    </div>
  </div>
</PageLayout>
