---
---
<footer class="bg-brand-navy text-white mt-12">
  <div class="max-w-6xl mx-auto px-4 py-10 grid grid-cols-1 md:grid-cols-3 gap-8">
    <!-- Column 1: Contact -->
    <div>
      <h3 class="text-white text-lg font-bold mb-4 border-b border-brand-cyan pb-2">Contact Us</h3>
      <address class="not-italic text-gray-300 text-sm space-y-1">
        <p class="font-semibold text-white">Bright Futures School</p>
        <p>1 Friezland Lane</p>
        <p>Greenfield</p>
        <p>OL3 7EU</p>
        <p class="mt-3"><a href="tel:01457878738" class="text-brand-cyan hover:text-white">01457 878738</a></p>
        <p><a href="mailto:office@brightfuturesschool.co.uk" class="text-brand-cyan hover:text-white break-all">office@brightfuturesschool.co.uk</a></p>
      </address>
    </div>

    <!-- Column 2: Quick links -->
    <div>
      <h3 class="text-white text-lg font-bold mb-4 border-b border-brand-cyan pb-2">Quick Links</h3>
      <ul class="text-gray-300 text-sm space-y-2">
        <li><a href="/gallery" class="hover:text-brand-cyan">Gallery</a></li>
        <li><a href="/friends" class="hover:text-brand-cyan">Friends of BFS</a></li>
        <li><a href="/contact" class="hover:text-brand-cyan">Contact Us</a></li>
        <li><a href="/about/overview" class="hover:text-brand-cyan">Overview</a></li>
        <li><a href="/contact" class="hover:text-brand-cyan">Arrange a Visit</a></li>
        <li><a href="/ofsted" class="hover:text-brand-cyan">Ofsted</a></li>
        <li><a href="/safeguarding" class="hover:text-brand-cyan">Safeguarding</a></li>
      </ul>
    </div>

    <!-- Column 3: School hours + accreditation -->
    <div>
      <h3 class="text-white text-lg font-bold mb-4 border-b border-brand-cyan pb-2">School Hours</h3>
      <p class="text-gray-300 text-sm mb-1">Mon / Tue / Thu / Fri: <span class="text-white">9.15am – 2.15pm</span></p>
      <p class="text-gray-300 text-sm mb-6">Wednesday: <span class="text-white">10.00am – 3.00pm</span></p>

      <h3 class="text-white text-lg font-bold mb-3 border-b border-brand-cyan pb-2">Accreditation</h3>
      <div class="flex items-center gap-4 flex-wrap">
        <img src="/images/badges/ssat-member.png" alt="SSAT Member" class="h-10 bg-white rounded p-1" />
        <img src="/images/badges/asdan-registered.png" alt="ASDAN Registered" class="h-10 bg-white rounded p-1" />
        <a href="https://www.ceop.police.uk/Safety-Centre/" target="_blank" rel="noopener">
          <img src="/images/badges/ceop-click.gif" alt="Click CEOP - report online child abuse" class="h-10" />
        </a>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10 py-4 text-center text-gray-400 text-xs">
    &copy; {new Date().getFullYear()} Bright Futures School Limited. All rights reserved.
  </div>
</footer>
